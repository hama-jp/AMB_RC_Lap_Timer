* text=auto eol=lf

# Source code: always LF
*.go     text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.md     text eol=lf
*.sh     text eol=lf

# Windows-only batch / PowerShell: keep CRLF
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf

# Binary
*.bin    binary
*.png    binary
*.jpg    binary
*.zip    binary
